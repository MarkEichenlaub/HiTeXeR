diff --git a/asy-interp.js b/asy-interp.js
index ec139f72..a7e06119 100644
--- a/asy-interp.js
+++ b/asy-interp.js
@@ -29548,6 +29548,19 @@ function renderSVG(result, opts) {
       const numLines = cleanLabelLines.length || 1;
 
       const isSizeConstrained = !isAutoScaled && !hasUnitScale;
+      // A content label whose anchor sits OUTSIDE the crop box — e.g. 04561's
+      // caption "$f(t)=\frac{3t}{t-2}$" at (0, ymin-1), a full unit BELOW the
+      // box — is NOT reserved by the size() solver, which fits only the cropped
+      // geometry. Without expanding the viewBox for it the caption renders
+      // entirely below the canvas and is clipped (the figure comes out ~40px
+      // short, sizeScore ~0.90). This is distinct from axis TITLES (skipped at
+      // the crop guard below): those anchor ON the box edge and merely overhang
+      // into the thin arrow margin. Self-limiting — a label inside the box adds 0.
+      const _outsideCropBox = !!(axisLimits && axisLimits.crop &&
+        axisLimits.xmin !== null && axisLimits.xmax !== null &&
+        axisLimits.ymin !== null && axisLimits.ymax !== null && dc.pos &&
+        (dc.pos.y < axisLimits.ymin - 1e-6 || dc.pos.y > axisLimits.ymax + 1e-6 ||
+         dc.pos.x < axisLimits.xmin - 1e-6 || dc.pos.x > axisLimits.xmax + 1e-6));
       // For size()-constrained single-line labels: skip entirely (solver handles it).
       // Exception: tick labels, axis labels, dot labels, and rotated labels may
       // extend beyond the solver-computed geometry, so we still need to pad the
@@ -29589,7 +29602,7 @@ function renderSVG(result, opts) {
       // re-expand the viewBox here either, or 04454's grid would re-shrink. Tick
       // labels stay eligible (they sit inside the box; their pad is self-limiting).
       if (axisLimits && axisLimits.crop && dc._isAxisLabel && !dc._isTickLabel) continue;
-      if (isSizeConstrained && numLines <= 1 && !dc._isTickLabel && !dc._isAxisLabel && !dc._fromDot && !dc.labelTransform && !extendsHoriz && !extendsVert && !_tallMathSkip) continue;
+      if (isSizeConstrained && numLines <= 1 && !dc._isTickLabel && !dc._isAxisLabel && !dc._fromDot && !dc.labelTransform && !extendsHoriz && !extendsVert && !_tallMathSkip && !_outsideCropBox) continue;
       // Italic math labels (in KaTeX_Math) render wider than plain text; use a
       // larger char-width factor so viewBox pad covers the actual glyph extent.
       const hasMath = typeof dc.text === 'string' && /\$|\\/.test(dc.text);
