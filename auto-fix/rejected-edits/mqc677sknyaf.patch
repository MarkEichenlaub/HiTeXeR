+          // With no explicit Label align, place the label on the OUTSIDE of the
+          // axis (opposite the tick direction): below the x-axis (S) for an N
+          // tick, left of the y-axis (W) for an E tick — the AoPS cse5 default.
+          // An explicit Label align (e.g. 03351's align=dir(-90)) overrides this.
+          let align = (labelObj && labelObj.align) ? labelObj.align : makePair(-dirVec.x, -dirVec.y);
           const _fsT = (pen && pen.fontsize) || 12;
