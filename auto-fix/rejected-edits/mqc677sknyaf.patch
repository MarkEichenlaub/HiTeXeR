-        // Default tick direction = N (pair(0,1)) — same as Asymptote
-        if (!dirVec) dirVec = makePair(0, 1);
+        // Default tick direction: x-axis ticks point N (up) into the plot;
+        // y-axis ticks point E (right) into the plot — matching the AoPS cse5
+        // xtick/ytick convention. A y-tick defaulting to N would draw parallel
