+        const ay = (maxY - ag.ay) * pxPerUnitY;
+        const bx = (ag.bx - minX) * pxPerUnitX;
+        const by = (maxY - ag.by) * pxPerUnitY;
+        const _rgb = c => `rgb(${Math.round(c.r*255)},${Math.round(c.g*255)},${Math.round(c.b*255)})`;
