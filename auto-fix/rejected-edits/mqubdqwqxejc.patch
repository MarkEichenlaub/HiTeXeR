+    // axialshade(picture pic=currentpicture, path[] g, bool stroke=false,
+    //            pen pena, pair a, pen penb, pair b):
+    // Fill path g with an axial (linear) gradient running from color pena at
+    // world point a to color penb at world point b. Asymptote's PostScript
+    // `axial` shading pads to pena before a and penb after b. We emit one
+    // `fill` command carrying _axialGradient; the SVG emitter converts the two
+    // world endpoints to pixel space and emits a <linearGradient> with two
+    // stops (default spreadMethod="pad" matches the PS pad semantics).
+    // Common AoPS idiom: axialshade(circle(c,r), black,(x0,y0), palegray,(x1,y1))
+    // for a shaded sphere/ball (e.g. 12980's mallet head). Endpoints a/b are
+    // taken in the path's own (world) coordinate space, so this matches when g
+    // is an untransformed path; a shift()*path with literal a/b would not.
+    env.set('axialshade', (...args) => {
+      const pos = args.filter(a => !(a && a._named));
+      let target = currentPic;
+      let pathArg = null;
+      const pens = [];
+      const pairs = [];
+      for (const a of pos) {
+        if (a && a._tag === 'picture' && target === currentPic) { target = a; continue; }
+        if (isPath(a) && !pathArg) { pathArg = a; continue; }
+        if (Array.isArray(a) && a.length > 0 && isPath(a[0]) && !pathArg) { pathArg = a[0]; continue; }
+        if (isPen(a)) { pens.push(a); continue; }
+        if (isPair(a)) { pairs.push(a); continue; }
+      }
+      for (const a of args) {
+        if (a && a._named) {
+          if ('pic' in a && a.pic && a.pic._tag === 'picture') target = a.pic;
+          if ('g' in a && isPath(a.g)) pathArg = a.g;
+          if ('pena' in a && isPen(a.pena)) pens[0] = a.pena;
+          if ('penb' in a && isPen(a.penb)) pens[1] = a.penb;
+          if ('a' in a && isPair(a.a)) pairs[0] = a.a;
+          if ('b' in a && isPair(a.b)) pairs[1] = a.b;
+        }
+      }
+      if (!pathArg || pens.length < 2 || pairs.length < 2) return;
+      const ca = {r: pens[0].r || 0, g: pens[0].g || 0, b: pens[0].b || 0};
+      const cb = {r: pens[1].r || 0, g: pens[1].g || 0, b: pens[1].b || 0};
+      const line = args._line || 0;
+      const fillPen = clonePen(pens[0]);
+      fillPen.opacity = 1;
+      target.commands.push({
+        cmd: 'fill', path: pathArg, pen: fillPen, line,
+        _axialGradient: {
+          ax: pairs[0].x, ay: pairs[0].y,
+          bx: pairs[1].x, by: pairs[1].y,
+          ca, cb,
+        },
+      });
+    });
