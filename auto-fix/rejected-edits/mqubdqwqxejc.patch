+          `<stop offset="0%" stop-color="${_rgb(ag.ca)}"/>` +
+          `<stop offset="100%" stop-color="${_rgb(ag.cb)}"/>` +
+          `</linearGradient></defs>`
+        );
+        fill = `url(#${gid})`;
+      }
