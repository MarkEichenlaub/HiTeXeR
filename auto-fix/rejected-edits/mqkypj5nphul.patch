+        } else if (trimmed2.startsWith('{') && trimmed2.endsWith('}')) {
+          // Non-math text that was wrapped in the size command's grouping braces,
+          // e.g. "{\Large Anatomy of a Parabola}" → "Anatomy of a Parabola". The
+          // outer {...} is a TeX group scoping \Large; once the selector is
+          // stripped the braces are pure grouping and must NOT render as literal
+          // glyphs (this label routes to the plain-text SVG path, where { } draw).
+          // Only strip a single outer group that spans the whole string (depth
+          // returns to 0 solely at the final brace), so command-argument braces
+          // (the {Title} in \textbf{Title}) and multi-group labels ("{A} and
+          // {B}") are left intact. Escaped \{ \} (set-builder math) don't count.
+          let depth = 0, single = true;
+          for (let i = 0; i < trimmed2.length; i++) {
+            const c = trimmed2[i];
+            if (c === '{' && trimmed2[i - 1] !== '\\') depth++;
+            else if (c === '}' && trimmed2[i - 1] !== '\\') {
+              depth--;
+              if (depth === 0 && i !== trimmed2.length - 1) { single = false; break; }
+            }
+          }
+          if (single && depth === 0) displayText = trimmed2.slice(1, -1).trim();
         }
