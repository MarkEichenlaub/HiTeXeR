diff --git a/asy-interp.js b/asy-interp.js
index 80e54880..09fa08f1 100644
--- a/asy-interp.js
+++ b/asy-interp.js
@@ -10839,6 +10839,35 @@ function createInterpreter() {
     // D() — cse5/olympiad shorthand for draw that returns its path
     // In AoPS/cse5 convention, D() uses blue pen by default (unlike draw() which uses black)
     env.set('D', (...args) => {
+      // cse5 marked-point form: D(Label L, pair A, pen fontpen, pair align).
+      // This draws a DOT at A (with `pointpen`), places the label L at A using
+      // the optional font pen + alignment, and RETURNS the pair A so the point
+      // chains inside a path expression. AoPS uses it to label+dot+connect every
+      // vertex in one expression, e.g.
+      //   draw(D("A",A,s,dir(90))--D("B",B,s,SW)--A--D("E",E,s,S)--C--...);
+      // Without this branch the call (a string + two pairs, no path) fell
+      // through to the path-draw form, which found no path and returned an
+      // EMPTY path — collapsing the whole chain to the few segments between the
+      // bare points and dropping every vertex dot (00600 drew only A--C).
+      {
+        let hasStrL = false, hasPathL = false, firstPairL = null;
+        for (const a of args) {
+          if (isString(a)) hasStrL = true;
+          else if (isPath(a)) hasPathL = true;
+          else if ((isPair(a) || isTriple(a) || isPoint(a)) && !firstPairL) firstPairL = a;
+        }
+        if (hasStrL && firstPairL && !hasPathL) {
+          // Place the label via MP (handles $...$ wrapping, align defaults).
+          const mp = env.get('MP');
+          const placed = (typeof mp === 'function') ? mp(...args) : firstPairL;
+          // Draw the vertex dot with pointpen (cse5's D draws the dot itself).
+          const ptp = env.get('pointpen');
+          const dotArgs = [firstPairL, (isPen(ptp) ? ptp : clonePen(defaultPen))];
+          dotArgs._line = args._line;
+          evalDot(dotArgs);
+          return placed || firstPairL;
+        }
+      }
       // cse5 overloads D(): a lone pair/point draws a DOT with `pointpen`
       //     D(pair A, pen p=pointpen) { dot(A,p); }
       // while a path draws with `pathpen`
