diff --git a/asy-interp.js b/asy-interp.js
index 3f17a4c1..1bca78a2 100644
--- a/asy-interp.js
+++ b/asy-interp.js
@@ -11471,7 +11471,14 @@ function createInterpreter() {
     });
     env.set('EndPoint', 1);
     env.set('BeginPoint', 0);
-    env.set('MidPoint', 0.5);
+    // Asymptote defines `position MidPoint=Relative(0.5)` (plain_arrows.asy),
+    // NOT a bare real. As a bare 0.5, `draw(..., Arrow(MidPoint))` was parsed
+    // by the Arrow constructor's numeric-arg scan as a 0.5bp arrow SIZE (an
+    // invisible head) instead of a relative arc-length POSITION, so MidPoint
+    // arrowheads vanished (05147 ship-frame V diagram). Make it a relative
+    // tagged object; valueOf() keeps numeric coercion working for any caller
+    // that uses MidPoint in label arithmetic.
+    { const _mp = {_tag:'relative', t:0.5}; _mp.valueOf = () => 0.5; env.set('MidPoint', _mp); }
     // Relative(real r) — relative position along a path (0=begin, 1=end).
     // Returns a tagged object so Arrow(Relative(t)) can distinguish a position
     // from a size argument. valueOf() makes numeric coercion (label arithmetic) work.
