     // labels (e.g. 07413's "$18+83i$" coordinate tags, _maxLblW≈45) by ~30%,
@@ -27262,7 +27270,22 @@ function renderSVG(result, opts) {
           // compact figures whose labels surround the geometry.
           const geomRefMax = Math.max(svgW, svgH);
           const liW = svgW * overshootScaleW, liH = svgH * overshootScaleH;
-          const fit = Math.min(1, geomRefMax / Math.max(liW, liH, 1e-9));
+          let fit = Math.min(1, geomRefMax / Math.max(liW, liH, 1e-9));
+          // 3D projected diagrams with single-char corner tags (cube ABCDEFGH in
+          // 10243) fit the whole label-inclusive picture to geomRefMax =
+          // defaultSize here; TeXeR binds these ~4% tighter, so HTX renders them
+          // ~3% oversized (sizeScore 0.976, capping combined at ~0.89). Bind 0.96
+          // to match — but ONLY when the label overshoot is ASYMMETRIC: one axis
+          // carries the corner-tag overshoot (>=1.12) while the OTHER stays modest
+          // (<1.15), leaving room to shrink without the fixed-size (truesize)
+          // labels colliding. Balanced high-overshoot layouts (labels tight on all
+          // sides, e.g. 00871/00900 with osW~osH~1.2) are EXCLUDED — shrinking
+          // them pulls truesize tags into the geometry and tanks ssim ~0.05.
+          // Controls (03335/04373/04611) never reach this clamp at all.
+          if (_is3D && Math.max(overshootScaleW, overshootScaleH) >= 1.12 &&
+              Math.min(overshootScaleW, overshootScaleH) < 1.15) {
+            fit *= 0.96;
+          }
           const fW = overshootScaleW * fit, fH = overshootScaleH * fit;
           svgW *= fW; svgH *= fH;
           intrinsicW *= fW; intrinsicH *= fH;
