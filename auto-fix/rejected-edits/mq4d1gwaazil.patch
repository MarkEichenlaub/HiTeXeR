+    // label-surrounded compact projections, so let it size them alone.
+    const _shortLabelFit = !_existingFitGate && !_is3D && maxDim > 5 && _maxLblW <= 40;
     // Skip this (geometry-only-bbox) shrink for the wide-label medium/large-2D
