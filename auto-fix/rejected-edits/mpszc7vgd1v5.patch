@@ -10804,11 +10804,19 @@ function createInterpreter() {
             curSeg = [];
             continue;
           }
-          // Detect large y-jumps (asymptotes) — break path if jump exceeds visible range
+          // Detect large y-jumps (asymptotes). A jump that CROSSES the axis
+          // (opposite signs, both large) is a pole crossing — break the path so
+          // we don't draw a spurious line linking +inf to -inf. A large
+          // SAME-SIGN jump is a steep one-sided approach to an asymptote (e.g.
+          // f(x)=1/(x-c) sampled with an endpoint placed right next to the pole,
+          // as in 00091's graph(f,xmin,332.999)). Keep that point so the branch
+          // reaches the crop edge, where limits(...,Crop) clips it — dropping it
+          // truncates the spike and collapses the diagram's height.
           if (curSeg.length > 0) {
             const prev = curSeg[curSeg.length - 1];
             const yRange = _yRangeUseful ? (_axisLimits.ymax - _axisLimits.ymin) : 100;
-            if (Math.abs(pt.y - prev.y) > yRange * 2) {
+            const crossesAxis = (pt.y > 0) !== (prev.y > 0);
+            if (Math.abs(pt.y - prev.y) > yRange * 2 && crossesAxis) {
               if (curSeg.length >= 2) segments.push(curSeg);
               curSeg = [];
             }
