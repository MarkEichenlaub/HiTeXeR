pair B=(0,0), A= (1,2), C= (3,0);
real c = length(B-A), b= length(A-C), a= length(C-B);
pair D = b/(b+c)*B + c/(b+c)*C;
draw(A--B--C--cycle);
draw(A--D);
label("$X$",A,N);
label("$Y$",B,SW);
label("$Z$",C,SE);
label("$W$",D,S);
label("$y$",.5*A+.5*C,NE);
label("$z$",.5*A+.5*B,NW);
label("$w$",.5*A+.5*D,SE)