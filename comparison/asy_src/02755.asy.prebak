size(0, 140);
real theta = 55;
pair P = dir(theta);
pair F = (Cos(theta), 0);
pair X = (-1,0);
draw((-1.3,0)--(1.5,0), Arrow);
draw((0, -1.3)--(0, 1.5), Arrow);
draw(circle((0,0), 1));
draw(X--P--F);
draw((0,0)--P);
draw(rightanglemark(X, F, P, 3));
label("$\theta$", (0,0), 2*dir(theta/2));
label("$\frac{1}{2}\theta$", X, 5*dir(theta/4));
label("$P = (\cos \theta, \sin \theta)$", P, NE);
label("$F$", F, NE);
label("$X$", X, NW)