import olympiad; 
import cse5; 
import geometry; 
size(150);
defaultpen(fontsize(10pt));
defaultpen(0.8);dotfactor=4;
pair O = origin;
pair A = O+dir(0);
pair U = O+dir(45);
pair L = O+dir(-45);
pair B1 = O+0.4*dir(20);pair B2 = A+0.4*dir(20);
draw(O--U);draw(O--L);draw(O--A);draw(L--A);draw(U--A);draw(O--B1,dotted);draw(A--B2);draw(B1--B2,dotted);draw(B1--U,dotted);draw(B1--L,dotted);draw(B2--L);draw(B2--U)