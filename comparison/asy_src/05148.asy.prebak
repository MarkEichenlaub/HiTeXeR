//unitsize(3cm);
size(200);

void ship(pair pos, real v, string name){
\tdraw(shift(pos)* box((0,0),(2,1)));
\tlabel(name,pos+(.1,.5),E);
}

ship((0,.5),0,"A'");
draw((1,.5),rotate(30)*scale(1.5mm)*cross(6) ,red+2);
draw((0.9, 0.5)--(0.9, 1.5), Arrow);
draw((1.1, 1.5)--(1.1, 0.5), Arrow);
draw("$h$", (1, 0.5)--(1, 1.5), dashed);