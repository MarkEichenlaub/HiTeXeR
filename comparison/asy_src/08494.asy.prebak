size(130);
real gamma = -15, alpha = 50;
pair C = dir(gamma), A = dir(alpha), B = (Cos(alpha), Sin(gamma));
pair O = (0,0), M = (A+C)/2, H = .5*(B + reflect(A,C)*B);
draw(A--B--C--cycle);
draw(arc((0,0), 1, -45, gamma));
draw(arc((0,0), 1, alpha, 80));
draw(A--O--C);
draw(O--M, dashed);
draw(B--H, dashed);
draw(B--(.5*(B+ reflect(O,M)*B)), dotted);
label("$O$", O, SW);
label("$B$", B, S);
label("$A$", A, NE);
label("$C$", C, ESE);
label("$H$", H, ENE);
label("$M$", M, NE)