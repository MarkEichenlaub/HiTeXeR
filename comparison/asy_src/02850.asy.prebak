size(100); pair B = dir(230), C = dir(-30), O = (0,0); draw(circle(O, 1));  draw(B--C); label("$a$", (B+C)/2, S); draw(B--O--C); pair A = dir(110); //draw(B--A--C, dotted);
pair Ap = -1*C; draw(Ap--B--C--cycle); label("$A'$", Ap, NW); label("$B$", B, SW); label("$C$", C, SE);draw(rightanglemark(Ap, B,C))