__pycache__/
*.pyc
*.asy
*.pdf
*.svg
*.png
*.aux
*.log
/tmp/
nul

# Claude agent prompt files (trigger injection defense if read during exploration)
_autofix_opus_prompt_*.txt
_autofix_opus_size_prompt_*.txt
_fix_prompt.txt
_autofix_tmp/

# Temp debug/test scripts and logs
debug-*.js
test-*.js
_check_*.js
_save_*.js
recompute-log.txt
refetch-log.txt

# Runtime-only state — survives git reset --hard so data is never lost.
auto-fix/droplist.json
auto-fix/attempts.jsonl
auto-fix/exclude-history.jsonl
comparison/blink-manifest.json
comparison/fix-history.html

# Ephemeral loop control / status — must NOT be committed. If checked in, the
# kill-switch (STOP) is re-armed by every `git reset --hard origin/master`
# (including run-loop's own syncToOrigin), so the loop can never start.
auto-fix/STOP
auto-fix/.run-loop-pid
auto-fix/.status.json
auto-fix/.queue-recovery.json

# Canary run outputs
_canary_*.jsonl
_canary_*.err

# Pipeline analysis / regression artifacts
_bottom500_*.txt
_bottom500_*.json
_combined_fetch_ids.txt
_compare_refetch.js
_missing_refs_*.txt
_refetch_main.txt
_regression_*.txt
_regression_blink.txt
_refetch_ids.txt
_refetch_progress.json
_refetch_summary.json

# \t-corruption repair backups (corrupted originals; recoverable, not tracked)
*.ctabbak
*.prebak
*.tabbak

# label-SSIM regression harness scratch dumps (regenerable via _regr_score.js)
_orphan_asy.bak
_before*.json
_after*.json
_lbl_katex.json
*_dump.log

# Temp scripts and probe outputs
_tmp_*.js
_lblprobe_out/

# Incident / analysis docs (keep locally, not in repo)
_*_INCIDENT_*.md

# External-source stress-test collections. The ext_* .asy/.png/.svg DATA is
# local-only (like the whole corpus — *.asy/*.png/*.svg already ignore it) and
# regenerable via extract-html.js + extract_pdf.py + ext-pipeline.js. Keep the
# raw doc downloads and analysis outputs out of git; keep the PDF extractor in.
/ext_sources/*
!/ext_sources/extract_pdf.py
comparison/localized_crops/
comparison/localized-scores.json
comparison/localized-review.html
comparison/feature-audit.json
comparison/feature-audit.txt

# opentype.js (added to node_modules; installed via npm install)
node_modules/opentype.js/
node_modules/.bin/ot
node_modules/.bin/ot.cmd
node_modules/.bin/ot.ps1
